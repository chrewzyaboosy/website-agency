# Netlify security headers (https://docs.netlify.com/routing/headers/)
# Applied at the edge; they do NOT affect opening files locally by double-click.
# CSP is split: the agency pages (self-hosted font, no third-party CDN) get a
# tight policy; the self-contained demo pages allow their inline CSS/JS + fonts.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000
  Cross-Origin-Opener-Policy: same-origin

# Agency pages: script-src 'self' (no inline JS). 'unsafe-inline' is allowed for
# styles only (a few inline style= attributes on the 404/blog/legal pages).
# Self-hosted font, so no Google Fonts hosts. loremflickr is for placeholder
# photos — drop it once you use your own images. Update form-action/connect-src
# if you change form providers.
/
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; upgrade-insecure-requests
/index.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; upgrade-insecure-requests
/404.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; upgrade-insecure-requests
/blog/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; upgrade-insecure-requests
/legal/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; upgrade-insecure-requests

# The demo pages are self-contained single files (inline <style> + <script>) and
# load their own Google Fonts.
/demos/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; form-action 'self'; upgrade-insecure-requests

# Long-cache the immutable, self-hosted fonts (rename the file to bust the cache).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
