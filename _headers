# Netlify security headers (https://docs.netlify.com/routing/headers/)
# These are applied by Netlify at the edge. They do NOT affect opening the
# files locally by double-click. CSP is split per-path so the main page can
# stay strict (no inline code) while the demo pages allow their inline CSS/JS.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000
  Cross-Origin-Opener-Policy: same-origin

# Main page runs React + Tailwind from CDNs (unpkg + cdn.tailwindcss.com).
# htm is used instead of Babel, so NO 'unsafe-eval' is needed. 'unsafe-inline'
# is required for the Tailwind runtime + config. If you switch form providers,
# update connect-src / form-action. (A production Vite build would let you drop
# the CDN allowances and 'unsafe-inline' entirely.)
/
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.tailwindcss.com; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; upgrade-insecure-requests
/index.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.tailwindcss.com; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; upgrade-insecure-requests

# The demo pages are self-contained single files (inline <style> + <script>),
# so they need 'unsafe-inline'. They take no user input and submit nowhere.
/demos/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https://loremflickr.com https://*.staticflickr.com; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; form-action 'self'; upgrade-insecure-requests
